{
  "name": "nuxt-app",
  "type": "module",
  "private": true,
  "module": "index.ts",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "dev:admin": "cd admin && pnpm dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "lint": "eslint .",
    "lintfix": "eslint . --fix",
    "setup": "bun ./scripts/_setup.ts",
    "test": "bun run test:unit && bun run test:e2e",
    "setup:db": "bun ./scripts/setupSupabaseDB.ts",
    "test:unit": "vitest run  --coverage",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@mdi/font": "^7.4.47",
    "@supabase/supabase-js": "^2.100.1",
    "@tsparticles/confetti": "^3.9.1",
    "nuxt": "^4.4.2",
    "vue": "3.5.25"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.7.3",
    "@nuxt/test-utils": "^4.0.0",
    "@playwright/test": "^1.58.2",
    "@types/decompress": "^4.2.7",
    "@types/node": "^24.12.0",
    "@vitest/coverage-v8": "4.1.2",
    "@vue/test-utils": "^2.4.6",
    "convert-csv-to-json": "^3.6.0",
    "decompress": "^4.2.1",
    "eslint": "10.1.0",
    "happy-dom": "^20.8.8",
    "sass": "^1.98.0",
    "typescript": "~6.0.2",
    "vite-plugin-vuetify": "^2.1.3",
    "vitest": "^4.1.2",
    "vuetify": "^3.12.4"
  }
}
